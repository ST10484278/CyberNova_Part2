<Window x:Class="CyberNova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberNova ChatBot"
        Height="700" Width="500"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat -->
            <RowDefinition Height="50"/>
            <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="CyberNova"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <TextBox x:Name="AsciiArtBox"
                     Height="125"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     Background="#2D2D2D"
                     Foreground="LightGreen"
                     BorderThickness="0"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

        <!-- ================= CHAT HISTORY ================= -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#252526">

            <TextBox x:Name="ChatHistory"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#252526"
                     Foreground="White"
                     BorderThickness="0"/>

        </ScrollViewer>

        <!-- ================= INPUT AREA ================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     Margin="0,5,5,5"
                     FontSize="14"
                     Padding="5"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    Margin="5"
                    Background="#007ACC"
                    Foreground="White"
                    Click="SendButton_Click"/>
        </Grid>

    </Grid>
</Window>